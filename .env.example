# Copy this file to .env and fill in the values

PORT=3000

# Supabase PostgreSQL connection string. 
# If empty, the app will use an in-memory SQLite database (data will be lost on restart).
DATABASE_URL=postgres://user:password@host:5432/dbname

# GitHub Pages origin — update when deploying
CORS_ORIGIN=http://localhost:5500

# Shared secret for /api/job/run (manual trigger endpoint)
JOB_SECRET=change-me-to-a-long-random-string

# Daily job schedule — HH:MM (24-hour, Europe/Rome timezone). Default: 22:00
JOB_TIME=22:00

# Google service account (JSON, single-line, base64-encoded)
GOOGLE_SERVICE_ACCOUNT_JSON=

# Gmail / SMTP for nodemailer
# For Gmail: enable 2-Step Verification on your Google account, then go to
#   https://myaccount.google.com/apppasswords
# and generate an "App Password" for "Mail / Other device".
# Use your full Gmail address as SMTP_USER and the 16-character app password as SMTP_PASS.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your-16-char-app-password

# WhatsApp Cloud API
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
